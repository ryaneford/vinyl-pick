# Discogs OAuth credentials
# Get these from https://www.discogs.com/settings/developers
# Note: These are hardcoded in the Dockerfile for the app to work
# DISCOGS_CONSUMER_KEY=your_consumer_key
# DISCOGS_CONSUMER_SECRET=your_consumer_secret

# OAuth callback URL (must match what's set in Discogs app settings)
# This should be the public URL where the app is hosted
NEXT_PUBLIC_OAUTH_CALLBACK=http://192.168.0.214:3000/api/oauth/callback